# Copiez ce fichier en .env et remplissez les valeurs
# Ne JAMAIS committer le fichier .env (il est ignoré par .gitignore)

# Base de données
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# Rails
RAILS_MASTER_KEY=

# Devise
DEVISE_SECRET_KEY=

# En production (Heroku) — ne pas remplir en local
# SMTP_USER=
# SMTP_PASSWORD=
